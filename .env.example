# ============================================================================
# AMC SOLUCIONES PERÚ — Variables de Entorno
# ----------------------------------------------------------------------------
# Copia este archivo a .env y completa los valores.
# NUNCA subir el .env real a git (está en .gitignore).
# ============================================================================

# Base de datos (SQLite dev / PostgreSQL prod)
# Dev:
DATABASE_URL="file:./db/custom.db"
# Prod (Vercel + Neon/Supabase):
# DATABASE_URL="postgresql://user:pass@host:port/dbname?schema=public"

# NextAuth.js
NEXTAUTH_SECRET="genera-con-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
# Prod:
# NEXTAUTH_URL="https://amcsolucionesperu.com"

# Email (Fase 5/6 — opcional)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_USER="ventas@amcsolucionesperu.com"
# SMTP_PASS="app-password"

# WhatsApp Cloud API (Fase 5/6 — opcional)
# WHATSAPP_TOKEN=""
# WHATSAPP_PHONE_NUMBER_ID=""

# Vercel Blob Storage (Fase 6 — para producción)
# BLOB_READ_WRITE_TOKEN=""
